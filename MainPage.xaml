<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Supernova.ViewModels"
             x:Class="Supernova.MainPage"
             x:Name="ThisPage"
             x:DataType="vm:MainViewModel"
             BackgroundColor="#1a1a2e">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ TOP BAR: connection status + nickname ═══ -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Padding="12,8" BackgroundColor="#16213e">
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <Ellipse WidthRequest="10" HeightRequest="10"
                         Fill="{Binding ConnectionColor}"
                         VerticalOptions="Center"/>
                <Label Text="{Binding ConnectionStatus}"
                       TextColor="#a0a0a0" FontSize="12"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Label Grid.Column="1"
                   Text="{Binding Nickname, StringFormat='You: {0}'}"
                   TextColor="White" FontSize="14" FontAttributes="Bold"
                   VerticalOptions="Center" HorizontalOptions="Center"/>

            <Entry Grid.Column="2"
                   Text="{Binding NicknameEntry}"
                   Placeholder="New name..."
                   PlaceholderColor="#707070"
                   TextColor="White" BackgroundColor="#0f3460"
                   WidthRequest="160" VerticalOptions="Center"
                   ReturnCommand="{Binding ChangeNameCommand}"
                   Margin="0,0,4,0"/>
            <Button Grid.Column="3" Text="Rename"
                    Command="{Binding ChangeNameCommand}"
                    BackgroundColor="#533483" TextColor="White"
                    FontSize="12" Padding="12,6"
                    VerticalOptions="Center"/>
        </Grid>

        <!-- ═══ MAIN: users sidebar + chat ═══ -->
        <Grid Grid.Row="1" ColumnDefinitions="220,*">

            <!-- ── Users sidebar ── -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*" BackgroundColor="#16213e">
                <Label Grid.Row="0" Text="Online Users"
                       FontAttributes="Bold" FontSize="16" TextColor="White"
                       Padding="12,10"/>
                <CollectionView Grid.Row="1" ItemsSource="{Binding Users}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:UserDisplay">
                            <Grid ColumnDefinitions="*,Auto,Auto" Padding="12,6" HeightRequest="44">
                                <Label Text="{Binding Nickname}" TextColor="White"
                                       FontSize="14" VerticalOptions="Center"
                                       LineBreakMode="TailTruncation"/>
                                <Button Grid.Column="1" Text="&#x1F4DE;" FontSize="16"
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.VoiceCallCommand}"
                                        CommandParameter="{Binding .}"
                                        Padding="4" WidthRequest="36" HeightRequest="36"/>
                                <Button Grid.Column="2" Text="&#x1F4F9;" FontSize="16"
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.VideoCallCommand}"
                                        CommandParameter="{Binding .}"
                                        Padding="4" WidthRequest="36" HeightRequest="36"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="No other users online"
                               TextColor="#707070"
                               HorizontalOptions="Center" Margin="0,20,0,0" FontSize="13"/>
                    </CollectionView.EmptyView>
                </CollectionView>
            </Grid>

            <!-- ── Chat area ── -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto" BackgroundColor="#1a1a2e">

                <CollectionView x:Name="ChatList" Grid.Row="0"
                                ItemsSource="{Binding Messages}"
                                Margin="8,4"
                                ItemsUpdatingScrollMode="KeepLastItemInView">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MessageDisplay">
                            <Grid Padding="4,2">
                                <Border BackgroundColor="{Binding BubbleColor}"
                                       StrokeShape="RoundRectangle 12"
                                       Padding="12,8"
                                       HorizontalOptions="{Binding HorizontalAlign}"
                                       MaximumWidthRequest="500"
                                       Stroke="Transparent">
                                    <VerticalStackLayout Spacing="2">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding Sender}"
                                                   TextColor="#b0b0ff" FontSize="11"
                                                   FontAttributes="Bold"/>
                                            <Label Text="{Binding Time}"
                                                   TextColor="#808080" FontSize="10"/>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding Text}"
                                               TextColor="White" FontSize="14"/>
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Message input -->
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Padding="8" BackgroundColor="#16213e">
                    <Entry Text="{Binding MessageText}"
                           Placeholder="Type a message..."
                           PlaceholderColor="#707070"
                           TextColor="White" BackgroundColor="#0f3460"
                           FontSize="14" Margin="0,0,8,0"
                           ReturnCommand="{Binding SendMessageCommand}"/>
                    <Button Grid.Column="1" Text="Send"
                            Command="{Binding SendMessageCommand}"
                            BackgroundColor="#533483" TextColor="White"
                            FontSize="14" Padding="16,8"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══ CALL PANEL (bottom bar) ═══ -->
        <Border Grid.Row="2" IsVisible="{Binding IsInCall}"
                BackgroundColor="#0f3460" Padding="12"
                Stroke="#533483" StrokeThickness="1">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                <Label Grid.Row="0" Grid.ColumnSpan="2"
                       Text="{Binding CallStatusText}" TextColor="White"
                       FontSize="16" FontAttributes="Bold"/>

                <!-- Call action buttons -->
                <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8" Margin="0,8,0,0">
                    <Button Text="Accept" BackgroundColor="#2ecc71" TextColor="White"
                            IsVisible="{Binding IsIncomingCall}"
                            Command="{Binding AcceptCallCommand}"
                            Padding="16,8"/>
                    <Button Text="Decline" BackgroundColor="#e74c3c" TextColor="White"
                            IsVisible="{Binding IsIncomingCall}"
                            Command="{Binding DeclineCallCommand}"
                            Padding="16,8"/>
                    <Button Text="End Call" BackgroundColor="#e74c3c" TextColor="White"
                            Command="{Binding EndCallCommand}"
                            Padding="16,8"/>
                </HorizontalStackLayout>

                <!-- Remote video preview -->
                <Image Grid.Row="1" Grid.Column="0"
                       Source="{Binding RemoteVideoFrame}"
                       IsVisible="{Binding IsVideoCall}"
                       HeightRequest="180" WidthRequest="320"
                       Aspect="AspectFit"
                       HorizontalOptions="Start" Margin="0,8,0,0"/>
            </Grid>
        </Border>
    </Grid>

</ContentPage>
