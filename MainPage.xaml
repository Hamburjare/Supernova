<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Supernova.MainPage"
             Title="Supernova">

    <Grid RowDefinitions="Auto,*" Padding="12" RowSpacing="12">
        <Border Grid.Row="0" StrokeShape="RoundRectangle 10" Padding="10">
            <VerticalStackLayout Spacing="8">
                <Label Text="Supernova"
                       FontAttributes="Bold"
                       FontSize="20" />

                <Label Text="{Binding StatusText}" />

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Entry Grid.Column="0"
                           Placeholder="Set your display name"
                           Text="{Binding PendingName}"
                           Completed="OnSetNameCompleted" />
                    <Button Grid.Column="1"
                            Text="Set Name"
                            Clicked="OnSetNameClicked" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="220,*" ColumnSpacing="12">
            <Border Grid.Column="0" StrokeShape="RoundRectangle 10" Padding="10">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Users"
                           FontSize="16"
                           FontAttributes="Bold" />

                    <CollectionView ItemsSource="{Binding Users}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="4,2">
                                    <Label Grid.Column="0"
                                         Text="{Binding PresenceIcon}" />
                                    <Label Grid.Column="1"
                                           Text="{Binding DisplayName}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Grid.Column="1" StrokeShape="RoundRectangle 10" Padding="10">
                <Grid RowDefinitions="*,Auto" RowSpacing="8">
                    <CollectionView x:Name="MessagesList"
                                    Grid.Row="0"
                                    ItemsSource="{Binding Messages}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid RowDefinitions="Auto,Auto" Padding="4,6">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding SenderName}"
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding SentLocalTime}"
                                               FontSize="12"
                                               Opacity="0.7" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1"
                                           Text="{Binding Text}"
                                           LineBreakMode="WordWrap" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0"
                               Placeholder="Message #general"
                               Text="{Binding PendingMessage}"
                               Completed="OnSendMessageCompleted" />
                        <Button Grid.Column="1"
                                Text="Send"
                                Clicked="OnSendMessageClicked" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
