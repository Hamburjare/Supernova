<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Supernova.ViewModels"
             x:Class="Supernova.MainPage"
             x:Name="ThisPage"
             x:DataType="vm:MainViewModel"
             BackgroundColor="#000000">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ TOP BAR ═══ -->
        <Border Grid.Row="0" BackgroundColor="#14213d"
                StrokeThickness="0"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                <!-- Connection indicator -->
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <Ellipse WidthRequest="8" HeightRequest="8"
                             Fill="{Binding ConnectionColor}"
                             VerticalOptions="Center"/>
                    <Label Text="{Binding ConnectionStatus}"
                           TextColor="#e5e5e5" FontSize="11"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Current nickname -->
                <Label Grid.Column="1"
                       Text="{Binding Nickname, StringFormat='You: {0}'}"
                       TextColor="#ffffff" FontSize="14" FontAttributes="Bold"
                       VerticalOptions="Center" HorizontalOptions="Center"/>

                <!-- Rename entry -->
                <Border Grid.Column="2" BackgroundColor="#1b2d52"
                        StrokeShape="RoundRectangle 8"
                        Stroke="#fca311" StrokeThickness="1"
                        Padding="0" VerticalOptions="Center">
                    <Entry Text="{Binding NicknameEntry}"
                           Placeholder="New name..."
                           PlaceholderColor="#6E6E6E"
                           TextColor="#ffffff" BackgroundColor="Transparent"
                           WidthRequest="150" HeightRequest="36"
                           FontSize="13" Margin="8,0"
                           ReturnCommand="{Binding ChangeNameCommand}"/>
                </Border>

                <Button Grid.Column="3" Text="Rename"
                        Command="{Binding ChangeNameCommand}"
                        BackgroundColor="#fca311" TextColor="#000000"
                        FontSize="12" FontAttributes="Bold"
                        CornerRadius="8" Padding="14,8"
                        VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- ═══ MAIN: users sidebar + chat ═══ -->
        <Grid Grid.Row="1" ColumnDefinitions="240,*" ColumnSpacing="0">

            <!-- ── Users sidebar ── -->
            <Border Grid.Column="0" BackgroundColor="#14213d"
                    StrokeThickness="0">
                <Grid RowDefinitions="Auto,*">
                    <!-- Sidebar header -->
                    <Border Grid.Row="0" BackgroundColor="#0d1629"
                            StrokeThickness="0" Padding="16,12">
                        <Label Text="Online Users"
                               FontAttributes="Bold" FontSize="15" TextColor="#fca311"/>
                    </Border>

                    <!-- User list -->
                    <CollectionView Grid.Row="1" ItemsSource="{Binding Users}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:UserDisplay">
                                <Border BackgroundColor="Transparent"
                                        StrokeThickness="0" Padding="12,8">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                                        <!-- User avatar circle -->
                                        <Border WidthRequest="32" HeightRequest="32"
                                                BackgroundColor="#1b2d52"
                                                StrokeShape="RoundRectangle 16"
                                                Stroke="#fca311" StrokeThickness="1.5"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding Initial}"
                                                   TextColor="#fca311" FontSize="13" FontAttributes="Bold"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>

                                        <Label Grid.Column="1" Text="{Binding Nickname}" TextColor="#ffffff"
                                               FontSize="13" VerticalOptions="Center"
                                               LineBreakMode="TailTruncation"/>

                                        <Button Grid.Column="2" Text="&#x1F4DE;" FontSize="14"
                                                BackgroundColor="Transparent"
                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.VoiceCallCommand}"
                                                CommandParameter="{Binding .}"
                                                Padding="2" WidthRequest="32" HeightRequest="32"
                                                VerticalOptions="Center"/>
                                        <Button Grid.Column="3" Text="&#x1F4F9;" FontSize="14"
                                                BackgroundColor="Transparent"
                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.VideoCallCommand}"
                                                CommandParameter="{Binding .}"
                                                Padding="2" WidthRequest="32" HeightRequest="32"
                                                VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="No other users online"
                                   TextColor="#6E6E6E" FontSize="12"
                                   HorizontalOptions="Center" Margin="0,20,0,0"/>
                        </CollectionView.EmptyView>
                    </CollectionView>
                </Grid>
            </Border>

            <!-- ── Chat area ── -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto" BackgroundColor="#000000">

                <!-- Messages -->
                <CollectionView x:Name="ChatList" Grid.Row="0"
                                ItemsSource="{Binding Messages}"
                                Margin="12,8"
                                ItemsUpdatingScrollMode="KeepLastItemInView">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MessageDisplay">
                            <Grid Padding="4,3">
                                <Border BackgroundColor="{Binding BubbleColor}"
                                       StrokeShape="RoundRectangle 14"
                                       Padding="14,10"
                                       HorizontalOptions="{Binding HorizontalAlign}"
                                       MaximumWidthRequest="520"
                                       Stroke="Transparent">
                                    <VerticalStackLayout Spacing="3">
                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="{Binding Sender}"
                                                   TextColor="{Binding SenderColor}" FontSize="11"
                                                   FontAttributes="Bold"/>
                                            <Label Text="{Binding Time}"
                                                   TextColor="#6E6E6E" FontSize="10"/>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding Text}"
                                               TextColor="{Binding TextColor}" FontSize="14"/>
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Message input bar -->
                <Border Grid.Row="1" BackgroundColor="#14213d"
                        StrokeThickness="0" Padding="12,10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Border BackgroundColor="#1b2d52"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#1b2d52" StrokeThickness="1"
                                Padding="0">
                            <Entry Text="{Binding MessageText}"
                                   Placeholder="Type a message..."
                                   PlaceholderColor="#6E6E6E"
                                   TextColor="#ffffff" BackgroundColor="Transparent"
                                   FontSize="14" Margin="12,0"
                                   ReturnCommand="{Binding SendMessageCommand}"/>
                        </Border>
                        <Button Grid.Column="1" Text="Send"
                                Command="{Binding SendMessageCommand}"
                                BackgroundColor="#fca311" TextColor="#000000"
                                FontSize="14" FontAttributes="Bold"
                                CornerRadius="10" Padding="20,10"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══ CALL PANEL ═══ -->
        <Border Grid.Row="2" IsVisible="{Binding IsInCall}"
                BackgroundColor="#14213d" Padding="16,12"
                StrokeShape="RoundRectangle 0"
                Stroke="#fca311" StrokeThickness="1.5">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="10">
                <Label Grid.Row="0" Grid.ColumnSpan="2"
                       Text="{Binding CallStatusText}" TextColor="#ffffff"
                       FontSize="15" FontAttributes="Bold"/>

                <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="10">
                    <Button Text="Accept" BackgroundColor="#2ecc71" TextColor="#ffffff"
                            IsVisible="{Binding IsIncomingCall}"
                            Command="{Binding AcceptCallCommand}"
                            CornerRadius="8" Padding="18,10" FontAttributes="Bold"/>
                    <Button Text="Decline" BackgroundColor="#e74c3c" TextColor="#ffffff"
                            IsVisible="{Binding IsIncomingCall}"
                            Command="{Binding DeclineCallCommand}"
                            CornerRadius="8" Padding="18,10" FontAttributes="Bold"/>
                    <Button Text="End Call" BackgroundColor="#e74c3c" TextColor="#ffffff"
                            Command="{Binding EndCallCommand}"
                            CornerRadius="8" Padding="18,10" FontAttributes="Bold"/>
                </HorizontalStackLayout>

                <Image Grid.Row="1" Grid.Column="0"
                       Source="{Binding RemoteVideoFrame}"
                       IsVisible="{Binding IsVideoCall}"
                       HeightRequest="180" WidthRequest="320"
                       Aspect="AspectFit"
                       HorizontalOptions="Start"/>
            </Grid>
        </Border>
    </Grid>

</ContentPage>
