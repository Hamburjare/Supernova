<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Supernova.MainPage"
             Title="Supernova">

    <Grid Padding="12">
        <Border StrokeShape="RoundRectangle 10"
                Padding="18"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                MaximumWidthRequest="520"
                IsVisible="{Binding IsLoginViewVisible}">
            <VerticalStackLayout Spacing="12">
                <Label Text="Supernova"
                       FontAttributes="Bold"
                       FontSize="26" />
                <Label Text="Sign in to start chatting."
                       FontSize="14" />
                <Label Text="{Binding AuthStateText}" />
                <Label Text="{Binding StatusText}" />
                <Button Text="Sign In"
                        Clicked="OnSignInClicked" />
            </VerticalStackLayout>
        </Border>

        <Grid IsVisible="{Binding IsChatViewVisible}"
              RowDefinitions="Auto,*"
              RowSpacing="12">
            <Border Grid.Row="0"
                    StrokeShape="RoundRectangle 10"
                    Padding="10">
                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="8">
                    <VerticalStackLayout Grid.Column="0"
                                         Spacing="4">
                        <Label Text="Supernova"
                               FontAttributes="Bold"
                               FontSize="20" />
                        <Label Text="{Binding StatusText}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="Settings"
                            Clicked="OnToggleSettingsClicked" />

                    <Button Grid.Column="2"
                            Text="Sign Out"
                            Clicked="OnSignOutClicked" />
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  ColumnDefinitions="220,*"
                  ColumnSpacing="12">
                <Grid Grid.Column="0"
                      RowDefinitions="Auto,*,Auto"
                      RowSpacing="8">
                    <!-- Users Panel -->
                    <Border Grid.Row="0"
                            StrokeShape="RoundRectangle 10"
                            Padding="10">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Users"
                                   FontSize="16"
                                   FontAttributes="Bold" />

                            <CollectionView ItemsSource="{Binding Users}"
                                            HeightRequest="150">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="8"
                                              Padding="4,2">
                                            <Label Grid.Column="0"
                                                   Text="{Binding PresenceIcon}" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding DisplayName}" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Voice Channels Panel -->
                    <Border Grid.Row="1"
                            StrokeShape="RoundRectangle 10"
                            Padding="10">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Voice Channels"
                                   FontSize="16"
                                   FontAttributes="Bold" />

                            <CollectionView ItemsSource="{Binding VoiceChannels}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <VerticalStackLayout Padding="4,4">
                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  ColumnSpacing="4">
                                                <Label Grid.Column="0"
                                                       Text="🔊"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontAttributes="Bold"
                                                       VerticalOptions="Center" />
                                                <Button Grid.Column="2"
                                                        Text="{Binding JoinButtonText}"
                                                        FontSize="10"
                                                        Padding="8,4"
                                                        HeightRequest="28"
                                                        Clicked="OnVoiceChannelJoinClicked"
                                                        CommandParameter="{Binding Id}" />
                                            </Grid>
                                            <!-- Members in channel -->
                                            <CollectionView ItemsSource="{Binding Members}"
                                                            Margin="20,4,0,0">
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid ColumnDefinitions="Auto,Auto,*"
                                                              ColumnSpacing="4"
                                                              Padding="2,1">
                                                            <Label Grid.Column="0"
                                                                   Text="{Binding StatusIcon}"
                                                                   FontSize="10" />
                                                            <BoxView Grid.Column="1"
                                                                     WidthRequest="4"
                                                                     HeightRequest="4"
                                                                     CornerRadius="2"
                                                                     Color="{Binding SpeakingIndicatorColor}"
                                                                     VerticalOptions="Center" />
                                                            <Label Grid.Column="2"
                                                                   Text="{Binding UserName}"
                                                                   FontSize="12" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Voice Controls (shown when in a channel) -->
                    <Border Grid.Row="2"
                            StrokeShape="RoundRectangle 10"
                            Padding="8"
                            IsVisible="{Binding IsInVoiceChannel}">
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="6">
                            <!-- Mic Level Indicator -->
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8">
                                <Label Text="🎤"
                                       VerticalOptions="Center" />
                                <ProgressBar Progress="{Binding MicLevel}"
                                             ProgressColor="{Binding MicLevelColor}"
                                             VerticalOptions="Center" />
                            </Grid>

                            <!-- Mute/Deafen Controls -->
                            <HorizontalStackLayout Grid.Row="1"
                                                   Spacing="8"
                                                   HorizontalOptions="Center">
                                <Button Text="{Binding MuteButtonText}"
                                        Clicked="OnMuteClicked"
                                        WidthRequest="80" />
                                <Button Text="{Binding DeafenButtonText}"
                                        Clicked="OnDeafenClicked"
                                        WidthRequest="80" />
                            </HorizontalStackLayout>

                            <!-- Leave Channel -->
                            <Button Grid.Row="2"
                                    Text="Leave Channel"
                                    BackgroundColor="#ff4444"
                                    TextColor="White"
                                    Clicked="OnLeaveVoiceChannelClicked" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Column="1"
                      RowDefinitions="Auto,*,Auto"
                      RowSpacing="8">
                    <Border Grid.Row="0"
                            StrokeShape="RoundRectangle 10"
                            Padding="10"
                            IsVisible="{Binding IsSettingsVisible}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Settings"
                                   FontAttributes="Bold"
                                   FontSize="16" />

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8">
                                <Entry Grid.Column="0"
                                       Placeholder="Set your display name"
                                       Text="{Binding PendingName}"
                                       Completed="OnSetNameCompleted" />
                                <Button Grid.Column="1"
                                        Text="Set Name"
                                        Clicked="OnSetNameClicked" />
                            </Grid>

                            <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                                  ColumnSpacing="8">
                                <Label Grid.Column="0"
                                       Text="Log"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="Copy"
                                        Clicked="OnCopyLogClicked" />
                                <Button Grid.Column="2"
                                        Text="Clear"
                                        Clicked="OnClearLogClicked" />
                            </Grid>

                            <Editor Text="{Binding LogText}"
                                    IsReadOnly="True"
                                    HeightRequest="120"
                                    AutoSize="TextChanges"
                                    Placeholder="Connection and auth logs will appear here." />

                            <!-- Voice Settings Section -->
                            <BoxView HeightRequest="1" Color="Gray" Margin="0,8" />
                            <Label Text="Voice Settings"
                                   FontAttributes="Bold"
                                   FontSize="14" />

                            <!-- Input Device -->
                            <Label Text="Input Device" FontSize="12" />
                            <Picker x:Name="InputDevicePicker"
                                    ItemsSource="{Binding InputDevices}"
                                    ItemDisplayBinding="{Binding Name}"
                                    SelectedItem="{Binding SelectedInputDevice}"
                                    SelectedIndexChanged="OnInputDeviceChanged" />

                            <!-- Output Device -->
                            <Label Text="Output Device" FontSize="12" />
                            <Picker x:Name="OutputDevicePicker"
                                    ItemsSource="{Binding OutputDevices}"
                                    ItemDisplayBinding="{Binding Name}"
                                    SelectedItem="{Binding SelectedOutputDevice}"
                                    SelectedIndexChanged="OnOutputDeviceChanged" />

                            <!-- Input Volume -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="Mic Volume" VerticalOptions="Center" FontSize="12" />
                                <Slider Grid.Column="1"
                                        Minimum="0" Maximum="2"
                                        Value="{Binding InputVolume}"
                                        ValueChanged="OnInputVolumeChanged" />
                                <Label Grid.Column="2"
                                       Text="{Binding InputVolumePercent, StringFormat='{0}%'}"
                                       VerticalOptions="Center"
                                       WidthRequest="40"
                                       FontSize="12" />
                            </Grid>

                            <!-- Output Volume -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="Output Volume" VerticalOptions="Center" FontSize="12" />
                                <Slider Grid.Column="1"
                                        Minimum="0" Maximum="2"
                                        Value="{Binding OutputVolume}"
                                        ValueChanged="OnOutputVolumeChanged" />
                                <Label Grid.Column="2"
                                       Text="{Binding OutputVolumePercent, StringFormat='{0}%'}"
                                       VerticalOptions="Center"
                                       WidthRequest="40"
                                       FontSize="12" />
                            </Grid>

                            <!-- Mic Sensitivity / VAD Threshold -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="Mic Sensitivity" VerticalOptions="Center" FontSize="12" />
                                <Slider Grid.Column="1"
                                        Minimum="0" Maximum="0.1"
                                        Value="{Binding MicSensitivity}"
                                        ValueChanged="OnMicSensitivityChanged" />
                                <Label Grid.Column="2"
                                       Text="{Binding MicSensitivityPercent, StringFormat='{0}%'}"
                                       VerticalOptions="Center"
                                       WidthRequest="40"
                                       FontSize="12" />
                            </Grid>
                            <Label Text="Lower = more sensitive (picks up quieter sounds)"
                                   FontSize="10"
                                   Opacity="0.6" />

                            <!-- Hear Self Toggle -->
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="Hear yourself (loopback)"
                                       VerticalOptions="Center"
                                       FontSize="12" />
                                <Switch IsToggled="{Binding HearSelf}"
                                        Toggled="OnHearSelfToggled" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1"
                            StrokeShape="RoundRectangle 10"
                            Padding="10">
                        <CollectionView x:Name="MessagesList"
                                        ItemsSource="{Binding Messages}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid RowDefinitions="Auto,Auto"
                                          Padding="4,6">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding SenderName}"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding SentLocalTime}"
                                                   FontSize="12"
                                                   Opacity="0.7" />
                                        </HorizontalStackLayout>
                                        <Label Grid.Row="1"
                                               Text="{Binding Text}"
                                               LineBreakMode="WordWrap" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <Entry Grid.Column="0"
                               Placeholder="Message #general"
                               Text="{Binding PendingMessage}"
                               Completed="OnSendMessageCompleted" />
                        <Button Grid.Column="1"
                                Text="Send"
                                Clicked="OnSendMessageClicked" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>

</ContentPage>
